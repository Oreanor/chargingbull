{
  "$schema": "longread-doc/v1",
  "_comment": [
    "Neutral intermediate document — what we extract from a Figma file (via",
    "Figma REST API, Figma Make output, or any other source). Not tied to the",
    "engine's component vocabulary. From this JSON a developer (or an LLM) can",
    "produce the actual MDX for the longread.",
    "",
    "Contract:",
    "  - `tokens` describes the design system used by this longread.",
    "    All section values reference tokens by name (e.g. 'accent') or give",
    "    literal CSS values; mixing is fine.",
    "  - `responsive` lists the breakpoints the designer worked in. Other",
    "    sections may carry their own per-breakpoint deltas under `responsive`.",
    "  - `sections` is the page in document order. Each section has a `type`",
    "    that identifies its visual role. The set is open — anything the",
    "    designer drew that doesn't fit common types goes through as",
    "    `type: 'custom'` plus a free-form payload."
  ],

  "source": {
    "kind": "figma-make",
    "fileKey": "LXoF4pY8I4w3H02GNxYKWZ",
    "url": "https://figma.com/design/LXoF4pY8I4w3H02GNxYKWZ",
    "extractedAt": "2026-05-24"
  },

  "name": "Dark Longread Design",

  "responsive": {
    "breakpoints": { "base": 0, "sm": 640, "lg": 1024 }
  },

